# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (transactional email) ───────────────────────────────────────────────
RESEND_API_KEY=

# ── Annature e-signature API ───────────────────────────────────────────────────
# Obtain from: https://app.annature.com.au → Settings → API
ANNATURE_ID=
ANNATURE_KEY=
ANNATURE_ACCOUNT_ID=

# Unified signer role used across all Bundle B templates
# Obtain from: https://app.annature.com.au → Settings → Roles
ANNATURE_BUNDLE_B_ROLE_ID=

# Bundle A — immediate signing pack (Position Description + Code of Conduct)
# One template ID per employment type × version combination
ANNATURE_BUNDLE_A_TEMPLATE_ID=

# Bundle B — contract signing pack (policy supplements)
# Obtain template IDs from the Annature template library
ANNATURE_BUNDLE_B_FLEXIBLE_WORKING_TEMPLATE_ID=
ANNATURE_BUNDLE_B_CORE_POLICY_TEMPLATE_ID=
ANNATURE_BUNDLE_B_HIGH_INTENSITY_TEMPLATE_ID=
ANNATURE_BUNDLE_B_BEHAVIOUR_SUPPORT_TEMPLATE_ID=

# ── Xero Payroll ───────────────────────────────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=
